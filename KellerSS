# ========================
# FUNГ‡ГѓO SCAN FAKE
# ========================
scan_fake() {

    clear

    steps=(
    "Identificando aparelho e ambiente..."
    "Verificando integridade de logs..."
    "Verificando root e ferramentas suspeitas..."
    "Verificando horГЎrio e uptime..."
    "Verificando ambiente e clipboard..."
    "Analisando MReplays..."
    "Checando bypass de Wallhack/Holograma..."
    "Checando Shaders..."
    "Checando OBB..."
    "Checando Optional..."
    )

    total_steps=${#steps[@]}
    duration=30
    start_time=$(date +%s)

    bar_size=30

    while true; do

        now=$(date +%s)
        elapsed=$((now - start_time))
        [ $elapsed -gt $duration ] && break

        progress=$((elapsed * 100 / duration))
        filled=$((elapsed * bar_size / duration))
        current_step=$((progress * total_steps / 100))

        clear

        # ========================
        # HEADER ORIGINAL
        # ========================
        echo ""
        echo -e "  \033[1;36mKellerSS Android\033[0m \033[38;2;70;130;180mFucking Cheaters\033[0m"
        echo -e "  \033[1;37mdiscord.gg/allianceoficial\033[0m"

        # ========================
        # ASCII COM SCAN LINE
        # ========================
        ascii=(
"  _  __       _ _           _____ ______"
" l l/ / ___ _l l l ___ _ _l   __/ ____l"
" l   < / _ \ l l l/ _ \ '__l l__ \___"
" l_l\_ \___,_l_l_l\___/_l   \____/_____"
        )

        scan_line=$((elapsed % ${#ascii[@]}))

        echo -e "\033[0;36m"
        for i in "${!ascii[@]}"; do
            if [ $i -eq $scan_line ]; then
                echo -e "\033[47m\033[30m${ascii[$i]}\033[0m"
            else
                echo "${ascii[$i]}"
            fi
        done
        echo -e "\033[0m"

        echo -e "  \033[0;36mCoded By: KellerSS\033[0m"
        echo ""

        # ========================
        # BOLINHAS VERTICAIS + BARRA
        # ========================

        printf "   \033[1;36mв—Џ\033[0m   "
        
        # barra
        bar="["
        for ((i=0;i<bar_size;i++)); do
            if [ $i -lt $filled ]; then
                bar+="\033[46m \033[0m"
            else
                bar+=" "
            fi
        done
        bar+="]"

        # tempo formatado
        printf -v time "%02d:%02d" $((elapsed/60)) $((elapsed%60))

        printf "%b   %3d%%  %s\n" "$bar" "$progress" "$time"

        printf "   \033[1;36mв—Џ\033[0m\n"
        printf "   \033[1;36mв—Џ\033[0m\n"

        echo ""

        # ========================
        # LISTA DE VERIFICAГ‡Г•ES
        # ========================
        for ((j=0; j<total_steps; j++)); do
            if [ $j -lt $current_step ]; then
                echo -e "  \033[0;32mвњ” ${steps[j]}\033[0m"
            elif [ $j -eq $current_step ]; then
                echo -e "  \033[1;34mвћњ ${steps[j]}\033[0m"
            else
                echo -e "  ${steps[j]}"
            fi
        done

        sleep 1
    done

    clear
    echo -e "\033[0;32mвњ” Scan concluГ­do!\033[0m"
    sleep 2
}
