#!/data/data/com.termux/files/usr/bin/bash

# ========================
# CORES
# ========================
CYAN="\033[0;36m"
BRIGHT_CYAN="\033[1;36m"
WHITE="\033[1;37m"
GREEN="\033[0;32m"
LIGHT_BLUE="\033[1;34m"
RED="\033[0;31m"
NC="\033[0m"

# ========================
# SCAN FAKE COM ASCII "SCAN LINE"
# ========================
scan_fake() {

    steps=(
    "Identificando aparelho..."
    "Verificando integridade..."
    "Checando root..."
    "Checando uptime..."
    "Verificando clipboard..."
    "Analisando logs..."
    "Checando Wallhack..."
    "Checando Shaders..."
    "Checando OBB..."
    "Finalizando..."
    )

    total_steps=${#steps[@]}
    duration=30
    bar_size=20
    start_time=$(date +%s)

    ascii=(
"  _  __       _ _           _____ ______"
" l l/ / ___ _l l l ___ _ _l   __/ ____l"
" l   < / _ \ l l l/ _ \ '__l l__ \___"
" l_l\_ \___,_l_l_l\___/_l   \____/_____"
    )

    while true; do

        now=$(date +%s)
        elapsed=$((now - start_time))
        [ $elapsed -gt $duration ] && break

        progress=$((elapsed * 100 / duration))
        filled=$((elapsed * bar_size / duration))
        current_step=$((progress * total_steps / 100))

        clear

        # HEADER
        echo ""
        echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${CYAN}Fucking Cheaters${NC}"
        echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"
        echo ""

        # ASCII COM LINHA BRANCA SCANNING
        scan_line=$(( (elapsed * 4) % ${#ascii[@]} ))
        for i in "${!ascii[@]}"; do
            if [ "$i" -eq "$scan_line" ]; then
                echo -e "\033[47m\033[30m${ascii[$i]}\033[0m"
            else
                echo -e "${CYAN}${ascii[$i]}${NC}"
            fi
        done
        echo ""
        echo -e "  ${CYAN}Coded By: KellerSS${NC}"
        echo ""

        # BARRA + BOLINHAS
        printf "   ${CYAN}●${NC}   "
        bar="["
        for ((i=0; i<bar_size; i++)); do
            if [ $i -lt $filled ]; then
                bar+="\033[46m \033[0m"
            else
                bar+=" "
            fi
        done
        bar+="]"

        printf -v time "%02d:%02d" $((elapsed/60)) $((elapsed%60))
        printf "%b   %3d%%  %s\n" "$bar" "$progress" "$time"

        printf "   ${CYAN}●${NC}\n"
        printf "   ${CYAN}●${NC}\n\n"

        # VERIFICAÇÕES
        for ((j=0; j<total_steps; j++)); do
            if [ $j -lt $current_step ]; then
                echo -e "  ${GREEN}✔ ${steps[j]}${NC}"
            elif [ $j -eq $current_step ]; then
                echo -e "  ${LIGHT_BLUE}➜ ${steps[j]}${NC}"
            else
                echo "  ${steps[j]}"
            fi
        done

        sleep 0.2
    done

    clear
    echo -e "${GREEN}✔ Scan concluído com sucesso!${NC}"
    sleep 2
}

