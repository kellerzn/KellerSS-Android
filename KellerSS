#!/data/data/com.termux/files/usr/bin/bash

# CORES
CYAN="\033[0;36m"
WHITE="\033[1;37m"
GREEN="\033[0;32m"
NC="\033[0m"

# ASCII para animação
ascii=(
"  _  __       _ _           _____ ______"
" l l/ / ___ _l l l ___ _ _l   __/ ____l"
" l   < / _ \ l l l/ _ \ '__l l__ \___"
" l_l\_ \___,_l_l_l\___/_l   \____/_____"
)

bar_size=20
tput civis  # esconde cursor

start_total=$(date +%s)

while true; do
    now=$(date +%s)
    elapsed=$((now - start_total))

    # -------------------------------
    # ASCII scan line
    # -------------------------------
    scan_line=$(( (elapsed*4) % ${#ascii[@]} ))
    for i in "${!ascii[@]}"; do
        if [ "$i" -eq "$scan_line" ]; then
            echo -e "\033[47m\033[30m${ascii[$i]}\033[0m"
        else
            echo -e "${CYAN}${ascii[$i]}${NC}"
        fi
    done

    echo ""


    )
    dots=${frames[$((elapsed % 3))]}

    # -------------------------------
    # Barra de progresso (enchendo gradualmente)
    # -------------------------------
    # Preenchimento cíclico apenas visual
    filled=$(( (elapsed % (bar_size+1)) ))
    bar="["
    for ((k=0;k<bar_size;k++)); do
        if [ $k -lt $filled ]; then
            bar+="\033[46m \033[0m"
        else
            bar+=" "
        fi
    done
    bar+="]"

    # Timer contínuo
    printf -v time "%02d:%02d" $((elapsed/60)) $((elapsed%60))

    # Linha única: bolinhas | barra | timer
    echo -e "${CYAN}${dots}${NC} $bar ${WHITE}${time}${NC}"

    sleep 0.1

    # Limpa apenas a linha da barra antes de redesenhar
    tput cuu 1
    tput el
done

tput cnorm