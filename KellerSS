#!/data/data/com.termux/files/usr/bin/bash
# Scanner FreeFire Normal - KellerSS Android Termux
# Autor: KellerSS (adaptado)

# ========================
# Cores ANSI
# ========================
BRIGHT_CYAN="\033[1;36m"
CYAN="\033[0;36m"
YELLOW_SCANNER="\033[1;93m"
ORANGE_SCANNER="\\033[48;5;202m"
GREEN_SCANNER="\033[48;5;202m"
LIGHT_CYAN="\033[1;96m"
WHITE="\033[1;37m"
GRAY="\033[0;37m"
GREEN="\033[0;32m"
NC="\033[0m"

# Azul destacado para "Fucking Cheaters"
BOX_CYAN="\033[38;2;0;180;255m"

# ========================
# Ocultar cursor
# ========================
echo -ne "\e[?25l"

# ========================
# Corrigir duplicação ao mudar resolução
# ========================
resize_flag=0
trap 'resize_flag=1' SIGWINCH

# ========================
# Restaurar terminal ao sair
# ========================
cleanup() {
    echo -ne "\e[?25h"
}
trap cleanup EXIT INT TERM

# ========================
# Configurações
# ========================
BAR_SIZE=20

items=("Identificando aparelho e ambiente..."
       "Verificando integridade de logs..."
       "Verificando root e ferramentas suspeitas..."
       "Verificando horário e uptime..."
       "Verificando ambiente e clipboard..."
       "Analisando MRplays..."
       "Checando bypass de Wallhack/Holograma..."
       "Checando Shaders..."
       "Checando OBB..."
       "Checando Optional...")

times=(5 3 3000 15 40 40 2 3 3 3)

TOTAL_ITEMS=${#items[@]}

status=()
for ((i=0;i<TOTAL_ITEMS;i++)); do
    status+=("future")
done

# Piscadinha da setinha + texto
blink_done=()
blink_state=()
for ((i=0;i<TOTAL_ITEMS;i++)); do
    blink_done[i]=0
    blink_state[i]=0
done

ascii_lines=(
"  _  __      _ _           _____ ______     "
" l l/ /___ _l l l ___ _ _l  ___/  ___l     "
" l   </ _ ' l l l/ _ \ '__l l__ \___ \\\\   "
" l_l\_\___,_l_l_l\___/_l   \____/_____/     "
)

spinner=("⠏" "⠛" "⠹" "⠼" "⠴" "⠦" "⠧" "⠇")
spinner_index=0

# ========================
# Função barra com scanner amarelo+laranja
# ========================
draw_bar() {
    current_index=$1
    timer=$2
    scanner_pos=$3

    percent=$(( (current_index+1) * 100 / TOTAL_ITEMS ))
    completed=$((current_index+1))

    filled=$(( BAR_SIZE * percent / 100 ))
    scanner_width=3

    bar="${WHITE}["

    for ((i=0;i<BAR_SIZE;i++)); do
        if [ $i -lt $filled ]; then
            bar+="${LIGHT_CYAN}█${NC}"
        else
            rel=$(( (i - scanner_pos + BAR_SIZE) % BAR_SIZE ))
            if [ $rel -lt $scanner_width ]; then
                if [ $rel -eq 0 -o $rel -eq 2 ]; then
                    bar+="${GREEN_SCANNER}░${NC}"  # scanner amarelo frente
                elif [ $rel -eq 1 ]; then
                    bar+="${ORANGE_SCANNER}░${NC}"  # scanner laranja atrás para profundidade
                fi
            else
                bar+="░" # fundo transparente
            fi
        fi
    done

    bar+="${WHITE}]${NC}"

    echo -ne "$bar $percent% $timer $completed/$TOTAL_ITEMS"
}

# ========================
# Loop principal
# ========================
start_time=$(date +%s)
highlight_index=0
scanner_pos=0

# Pré-preencher tela
clear
for ((i=0;i<40;i++)); do
    echo ""
done

for ((step=0; step<TOTAL_ITEMS; step++)); do
    for ((i=0;i<TOTAL_ITEMS;i++)); do
        if [ $i -lt $step ]; then
            status[$i]="done"
        elif [ $i -eq $step ]; then
            status[$i]="current"
        else
            status[$i]="future"
        fi
    done

    elapsed_item=0

    while [ $elapsed_item -lt ${times[$step]} ]; do
        if [ $resize_flag -eq 1 ]; then
            clear
            resize_flag=0
        fi

        current_time=$(date +%s)
        elapsed=$(( current_time - start_time ))
        minutes=$(( elapsed / 60 ))
        seconds=$(( elapsed % 60 ))
        timer=$(printf "%02d:%02d" $minutes $seconds)

        echo -ne "\033[H"

        # Cabeçalho
        echo ""
        echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${BOX_CYAN}Fucking Cheaters${NC}\033[K"
        echo -e "  ${WHITE}discord.gg/allianceoficial${NC}\033[K"
        echo ""

        # ASCII animado
        for ((i=0;i<${#ascii_lines[@]};i++)); do
            if [ $i -eq $highlight_index ]; then
                echo -e "${WHITE}${ascii_lines[$i]}${NC}\033[K"
            else
                echo -e "${BRIGHT_CYAN}${ascii_lines[$i]}${NC}\033[K"
            fi
        done
        highlight_index=$(( (highlight_index + 1) % ${#ascii_lines[@]} ))

        echo ""
        # Coded By em CYAN normal
        echo -e "${CYAN}  Coded By: KellerSS${NC}\033[K"
        echo ""

        echo -ne "${LIGHT_CYAN}${spinner[$spinner_index]}${NC} "

        draw_bar $step $timer $scanner_pos

        spinner_index=$(( (spinner_index + 1) % ${#spinner[@]} ))

        echo -e "\n"

        # Itens do scanner
        for ((i=0;i<TOTAL_ITEMS;i++)); do
            case ${status[$i]} in
                done)
                    echo -e "  ${GREEN}✔${NC} ${items[$i]}\033[K"
                ;;
                current)
                    # Setinha + texto piscando juntos, setinha LIGHT_CYAN, texto WHITE
                    if [ ${blink_done[$i]} -eq 0 ]; then
                        case ${blink_state[$i]} in
                            0)
                                echo -e "  ${LIGHT_CYAN}➤\033[7m ${WHITE}${items[$i]}\033[0m\033[K"
                                blink_state[$i]=1
                            ;;
                            1)
                                echo -e "  ${LIGHT_CYAN}➤ ${WHITE}${items[$i]}\033[K"
                                blink_state[$i]=2
                            ;;
                            2)
                                echo -e "  ${LIGHT_CYAN}➤\033[7m ${WHITE}${items[$i]}\033[0m\033[K"
                                blink_state[$i]=3
                            ;;
                            3)
                                echo -e "  ${LIGHT_CYAN}➤ ${WHITE}${items[$i]}\033[K"
                                blink_done[$i]=1
                            ;;
                        esac
                    else
                        echo -e "  ${LIGHT_CYAN}➤ ${WHITE}${items[$i]}\033[K"
                    fi
                ;;
                future)
                    echo -e "  ${GRAY}•${NC} ${items[$i]}\033[K"
                ;;
            esac
        done

        scanner_pos=$(( (scanner_pos + 1) % BAR_SIZE ))

        sleep 0.05
        ((elapsed_item++))
    done
done