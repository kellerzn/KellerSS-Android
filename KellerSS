scan_fake() {

    steps=(
    "Identificando aparelho..."
    "Verificando integridade..."
    "Verificando root..."
    "Checando uptime..."
    "Verificando clipboard..."
    "Analisando logs..."
    "Checando Wallhack..."
    "Checando Shaders..."
    "Checando OBB..."
    "Finalizando..."
    )

    # tempos individuais (segundos)
    times=(30 30 300 30 30 30 30 30 30 30)

    total_steps=${#steps[@]}
    bar_size=20

    tput civis  # esconder cursor

    # desenha layout fixo (SEM PISCAR)
    clear
    echo ""
    echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${CYAN}Fucking Cheaters${NC}"
    echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"
    echo ""

    ascii=(
"  _  __       _ _           _____ ______"
" l l/ / ___ _l l l ___ _ _l   __/ ____l"
" l   < / _ \ l l l/ _ \ '__l l__ \___"
" l_l\_ \___,_l_l_l\___/_l   \____/_____"
    )

    # imprime ascii base
    for line in "${ascii[@]}"; do
        echo -e "${CYAN}${line}${NC}"
    done

    echo -e "${CYAN}Coded By: KellerSS${NC}"
    echo ""

    # linha da barra
    bar_line=$(($(tput lines) - 15))

    for ((i=0; i<total_steps; i++)); do

        step_time=${times[$i]}
        start=$(date +%s)

        while true; do

            now=$(date +%s)
            elapsed=$((now - start))
            [ $elapsed -ge $step_time ] && break

            percent=$((elapsed * 100 / step_time))
            filled=$((elapsed * bar_size / step_time))

            # ASCII scan line (SEM PISCAR)
            scan_line=$(( (elapsed*3) % 4 ))
            for j in {0..3}; do
                tput cup $((4+j)) 2
                if [ $j -eq $scan_line ]; then
                    echo -ne "\033[47m\033[30m${ascii[$j]}\033[0m"
                else
                    echo -ne "${CYAN}${ascii[$j]}${NC}"
                fi
            done

            # barra
            tput cup 10 2
            bar="["
            for ((k=0;k<bar_size;k++)); do
                if [ $k -lt $filled ]; then
                    bar+="\033[46m \033[0m"
                else
                    bar+=" "
                fi
            done
            bar+="]"

            # timer
            printf -v time "%02d:%02d" $((elapsed/60)) $((elapsed%60))

            echo -ne "   ${CYAN}в—Џв—Џв—Џ${NC} $bar $time"

            # lista
            for ((j=0; j<total_steps; j++)); do
                tput cup $((12+j)) 2
                if [ $j -lt $i ]; then
                    echo -ne "${GREEN}вњ” ${steps[j]}${NC}     "
                elif [ $j -eq $i ]; then
                    echo -ne "${LIGHT_BLUE}вћњ ${steps[j]}${NC}     "
                else
                    echo -ne "${steps[j]}     "
                fi
            done

            sleep 0.1
        done
    done

    tput cnorm  # mostrar cursor
    tput cup $((12+total_steps)) 2
    echo -e "${GREEN}вњ” Scan concluГ­do!${NC}"
    sleep 2
}

