#!/data/data/com.termux/files/usr/bin/bash
# Script: KellerSS-Android Termux
# Autor: KellerSS
# Compatível com Termux (Android)

# Limpar tela
clear

# ========================
# Cores ANSI
# ========================
CYAN="\033[0;36m"
BOX_CYAN="\033[38;2;0;180;255m"
BRIGHT_CYAN="\033[1;36m"
LIGHT_BLUE="\033[1;34m"
WHITE="\033[1;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
DARK_PURPLE="\033[0;35m"
DARK_CYAN="\033[0;36m"
CYAN_AZULADO="\033[1;36m"
AZUL_PERSONAL="\033[38;2;70;130;180m"
NC="\033[0m"  # Sem cor

# ========================
# Título e Discord
# ========================
echo ""
echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${BOX_CYAN}Fucking Cheaters${NC}     "
echo -e "  ${WHITE}discord.gg/allianceoficial${NC}     "

# Ativa cor ciano
echo -e "${BRIGHT_CYAN}"

# ASCII Art linha por linha
echo "  _  __       _ _           _____ ______     "
echo " l l/ / ___ _l l l ___ _ _l  ___/ ____l     "
echo " l ' < / _｀ l l l/ _ \ '__l l__ \___ \\    "
echo " l_l\_ \___,_l_l_l\___/_l   \____/_____/     "

# Reseta cor
echo -e "${NC}"


echo -e "  ${CYAN}Coded By: KellerSS${NC}     "

echo ""
echo ""
# ========================
# Menu Principal
# ========================
echo -e "${LIGHT_BLUE}  ╔══════════════════════════╗     "
echo -e "  ║      MENU PRINCIPAL      ║     "
echo -e "  ╚══════════════════════════╝${NC}     "

# ========================
# Espaço entre menu e ADB
# ========================
echo ""

# ========================
# Status ADB (com espaço extra abaixo)
# ========================
echo -e "  ${WHITE}ADB: ${GREEN}● Dispositivo conectado${NC}     "
echo ""  # espaço abaixo do ADB

# ========================
# Opções
# ========================
echo -e "  ${YELLOW}[0]${WHITE} Parear Dispositivo${NC}     "
echo -e "  ${GREEN}[1]${WHITE} Escanear FreeFire Normal${NC}     "
echo -e "  ${GREEN}[2]${WHITE} Escanear FreeFire Max${NC}     "
echo -e "  ${GREEN}[3]${WHITE} Salvar Dump${NC}     "
echo -e "  ${RED}[S]${WHITE} Sair${NC}     "

# Linha em branco para empurrar o input pra baixo
echo ""

# ========================
# Prompt de escolha (bright cyan / arrow)
# ========================
echo -ne "  ${BRIGHT_CYAN}▸ Escolha uma das opções acima:${NC}${GREEN} "
read escolha

# ========================
# Lógica de escolha
# ========================
case $escolha in
    0)
        echo -e "${GREEN}Você escolheu: Parear Dispositivo${NC}     "
        exit 0
        ;;
    1)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Normal${NC}     "
        ;;
    2)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Max${NC}     "
        ;;
    3)
        echo -e "${GREEN}Você escolheu: Salvar Dump${NC}     "
        ;;
    [Ss])
        echo -e "${RED}Saindo...${NC}     "
        exit 0
        ;;
    *)
        echo -e "${RED}Opção inválida!${NC}     "
        ;;
esac