#!/data/data/com.termux/files/usr/bin/bash
clear

CYAN="\033[0;36m"
BRIGHT_CYAN="\033[1;36m"
BLUE="\033[0;34m"
WHITE="\033[1;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
NC="\033[0m"

# Título
echo -e "${BRIGHT_CYAN}KellerSS Android${NC} ${BLUE}Fucking Cheaters${NC}"
echo -e "${WHITE}discord.gg/allianceoficial${NC}"

# ASCII Art
echo -e "${CYAN}
 _  __       _ _            ______ ______
| |/ / ___ _| | | ___ _._|   ____/ ____|
|   < / _ \ | |/ _ \   __| |__ \\\___  \\
|_|\_ \___,_|_|_|\___/_ |   \____/_____
${NC}"

# Coded By separado e colorido
echo -e "${BRIGHT_CYAN}Coded By: KellerSS${NC}"

echo ""

# Menu Principal alinhado com opções
echo -e "${BLUE}╔══════════════════════════╗${NC}"
echo -e "${BLUE}║      MENU PRINCIPAL      ║${NC}"
echo -e "${BLUE}╚══════════════════════════╝${NC}"

echo ""  # espaço

# ADB alinhado com números
echo -e "ADB: ${GREEN}● Dispositivo conectado${NC}"

echo ""  # espaço

# Opções
echo -e "[0] Parear Dispositivo"
echo -e "[1] Escanear FreeFire Normal"
echo -e "[2] Escanear FreeFire Max"
echo -e "[3] Salvar Dump"
echo -e "[S] Sair"

echo ""  # espaço antes da seta

# Prompt de escolha
echo -e "${BRIGHT_CYAN}▸ Escolha uma das opções acima:${NC}"
read escolha

case $escolha in
    0)
        echo -e "${GREEN}Você escolheu: Parear Dispositivo${NC}"
        ;;
    1)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Normal${NC}"
        ;;
    2)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Max${NC}"
        ;;
    3)
        echo -e "${GREEN}Você escolheu: Salvar Dump${NC}"
        ;;
    [Ss])
        echo -e "${RED}Saindo...${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}Opção inválida!${NC}"
        ;;
esac
