#!/data/data/com.termux/files/usr/bin/bash
# Script: KellerSS-Android Termux
# Autor: KellerSS
# Compatível com Termux (Android)

# Limpar tela
clear

# ========================
# Cores ANSI
# ========================
CYAN="\033[0;36m"
BRIGHT_CYAN="\033[1;36m"  # ciano mais claro / bright cyan
BLUE="\033[0;34m"
WHITE="\033[1;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
NC="\033[0m"  # Sem cor

# ========================
# Título e Discord
# ========================
echo -e "${BRIGHT_CYAN}KellerSS Android${NC} ${BLUE}Fucking Cheaters${NC}"
echo -e "${WHITE}discord.gg/allianceoficial${NC}"

# ========================
# ASCII Art colado com o "Coded By"
# ========================
echo -e "${CYAN}
echo -e " _  __       _ _            ______ ______ "
echo -e "| |/ / ___ _| | | ___ _._|   ____/ ____|  "
echo -e "|   < / _ \ | | |/ _ \   __| |__ \___ \   "
echo -e "|_|\_ \___,_|_|_|\___/_ |   \____/_____/  "
echo -e "${NC}"
echo -e "${NC}"${BRIGHT_CYAN}Coded By: KellerSS${NC} "

# ========================
# Espaço acima do menu e ADB
# ========================
echo ""

# ========================
# Menu Principal
# ========================
echo -e "${BLUE}      ╔══════════════════════════╗"
echo -e "      ║      MENU PRINCIPAL      ║"
echo -e "      ╚══════════════════════════╝${NC}"

# ========================
# Espaço entre menu e ADB
# ========================
echo ""

# ========================
# Status ADB (com espaço extra abaixo)
# ========================
echo -e "ADB: ${GREEN}● Dispositivo conectado${NC}"
echo ""  # espaço abaixo do ADB

# ========================
# Opções
# ========================
echo -e "  ${YELLOW}[0]${WHITE} Parear Dispositivo${NC}"
echo -e "  ${GREEN}[1]${WHITE} Escanear FreeFire Normal${NC}"
echo -e "  ${GREEN}[2]${WHITE} Escanear FreeFire Max${NC}"
echo -e "  ${GREEN}[3]${WHITE} Salvar Dump${NC}"
echo -e "  ${RED}[S]${WHITE} Sair${NC}"

# Linha em branco para empurrar o input pra baixo
echo ""

# ========================
# Prompt de escolha (bright cyan / arrow)
# ========================
echo -e "  ${BRIGHT_CYAN}▸ Escolha uma das opções acima:${NC}"
read escolha

# ========================
# Lógica de escolha
# ========================
case $escolha in
    0)
        echo -e "${GREEN}Você escolheu: Parear Dispositivo${NC}"
        ;;
    1)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Normal${NC}"
        ;;
    2)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Max${NC}"
        ;;
    3)
        echo -e "${GREEN}Você escolheu: Salvar Dump${NC}"
        ;;
    [Ss])
        echo -e "${RED}Saindo...${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}Opção inválida!${NC}"
        ;;
esac