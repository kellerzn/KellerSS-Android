#!/data/data/com.termux/files/usr/bin/bash

clear

# ========================
# Cores ANSI
# ========================
CYAN="\033[0;36m"
BRIGHT_CYAN="\033[1;36m"
LIGHT_BLUE="\033[1;34m"
WHITE="\033[1;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
AZUL_PERSONAL="\033[38;2;70;130;180m"
NC="\033[0m"

# ========================
# FUNÇÃO SCAN FAKE
# ========================
scan_fake() {

    clear

    steps=(
    "Identificando aparelho e ambiente..."
    "Verificando integridade de logs..."
    "Verificando root e ferramentas suspeitas..."
    "Verificando horário e uptime..."
    "Verificando ambiente e clipboard..."
    "Analisando MReplays..."
    "Checando bypass de Wallhack/Holograma..."
    "Checando Shaders..."
    "Checando OBB..."
    "Checando Optional..."
    )

    total_steps=${#steps[@]}
    duration=30
    step_time=$((duration / total_steps))

    for ((i=0; i<total_steps; i++)); do
        for ((t=0; t<step_time; t++)); do

            clear

            # ========================
            # SEU ASCII ORIGINAL (SEM ALTERAR)
            # ========================
            echo ""
            echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${AZUL_PERSONAL}Fucking Cheaters${NC}"
            echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"

            echo -e "${CYAN}"
            echo "  _  __       _ _           _____ ______"
            echo " l l/ / ___ _l l l ___ _ _l   __/ ____l"
            echo " l   < / _ \ l l l/ _ \ '__l l__ \___"
            echo " l_l\_ \___,_l_l_l\___/_l   \____/_____"
            echo -e "${NC}"

            echo -e "  ${CYAN}Coded By: KellerSS${NC}"
            echo ""

            # ========================
            # BOLINHAS ANIMADAS
            # ========================
            dots=("● ● ●   ● ● ●" "● ○ ●   ● ○ ●" "○ ● ○   ○ ● ○")
            dot=${dots[$((t % 3))]}

            # ========================
            # PROGRESSO
            # ========================
            progress=$(( ( (i * step_time + t) * 100 ) / duration ))
            bar=""
            for ((b=0; b<progress/2; b++)); do bar+="█"; done

            printf "\n${LIGHT_BLUE}[%s] %3d%%${NC}\n" "$bar" "$progress"
            echo -e "${CYAN}${dot}${NC}\n"

            # ========================
            # VERIFICAÇÕES
            # ========================
            for ((j=0; j<total_steps; j++)); do
                if [ $j -lt $i ]; then
                    echo -e "${GREEN}✔ ${steps[j]}${NC}"
                elif [ $j -eq $i ]; then
                    echo -e "${LIGHT_BLUE}➜ ${steps[j]}${NC}"
                else
                    echo -e "  ${steps[j]}"
                fi
            done

            sleep 1
        done
    done

    clear
    echo -e "${GREEN}✔ Scan concluído com sucesso!${NC}"
    sleep 2
}

# ========================
# MENU PRINCIPAL
# ========================

echo ""
echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${AZUL_PERSONAL}Fucking Cheaters${NC}"
echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"

echo -e "${CYAN}"
echo "  _  __       _ _           _____ ______"
echo " l l/ / ___ _l l l ___ _ _l   __/ ____l"
echo " l   < / _ \ l l l/ _ \ '__l l__ \___"
echo " l_l\_ \___,_l_l_l\___/_l   \____/_____"
echo -e "${NC}"

echo -e "  ${CYAN}Coded By: KellerSS${NC}"
echo ""

echo -e "${LIGHT_BLUE}  ╔══════════════════════════╗"
echo -e "  ║      MENU PRINCIPAL      ║"
echo -e "  ╚══════════════════════════╝${NC}"

echo ""
echo -e "  ADB: ${GREEN}● Dispositivo conectado${NC}"
echo ""

echo -e "  ${YELLOW}[0]${WHITE} Parear Dispositivo${NC}"
echo -e "  ${GREEN}[1]${WHITE} Escanear FreeFire Normal${NC}"
echo -e "  ${GREEN}[2]${WHITE} Escanear FreeFire Max${NC}"
echo -e "  ${GREEN}[3]${WHITE} Salvar Dump${NC}"
echo -e "  ${RED}[S]${WHITE} Sair${NC}"

echo ""
echo -e "  ${BRIGHT_CYAN}▸ Escolha uma das opções acima:${NC}"
read escolha

case $escolha in
    0)
        echo -e "${GREEN}Você escolheu: Parear Dispositivo${NC}"
        ;;
    1)
        clear
        scan_fake
        ;;
    2)
        echo -e "${GREEN}Você escolheu: Escanear FreeFire Max${NC}"
        ;;
    3)
        echo -e "${GREEN}Você escolheu: Salvar Dump${NC}"
        ;;
    [Ss])
        echo -e "${RED}Saindo...${NC}"
        exit 0
        ;;
    *)
        echo -e "${RED}Opção inválida!${NC}"
        ;;
esac