#!/data/data/com.termux/files/usr/bin/bash
# Script: KellerSS-Android Termux
# Autor: KellerSS
# CompatГ­vel com Termux (Android)

clear

# ========================
# Cores ANSI
# ========================
CYAN="\033[1;36m"
BOX_CYAN="\033[38;2;0;200;220m"
LIGHT_CYAN="\033[1;96m"
WHITE="\033[1;37m"
GREEN="\033[0;32m"
ORANGE="\033[0;33m"
LIGHT_GREEN="\033[1;32m"
LIGHT_ORANGE="\033[1;33m"
GRAY="\033[0;37m"
NC="\033[0m"
BRIGHT_CYAN="\033[1;36m"
AZUL_PERSONAL="\033[38;2;70;130;180m"

# ========================
# ConfiguraГ§Гµes
# ========================
BAR_SIZE=20
items=("Identificando aparelho e ambiente..."
       "Verificando integridade de logs..."
       "Verificando root e ferramentas suspeitas..."
       "Verificando horГЎrio e uptime..."
       "Verificando ambiente e clipboard..."
       "Analisando MRplays..."
       "Checando bypass de Wallhack/Holograma..."
       "Checando Shaders..."
       "Checando OBB..."
       "Checando Optional...")
times=(5 5 3000 30 30 30 30 30 30 30)
TOTAL_ITEMS=${#items[@]}
status=()
for ((i=0;i<TOTAL_ITEMS;i++)); do
    status+=("future")
done

ascii_lines=(
"  _  __       _ _           _____ ______     "
" l l/ / ___ _l l l ___ _ _l   __/ ____l     "
" l   < / _ \ l l l/ _ \ '__l l__ \___     "
" l_l\_ \___,_l_l_l\___/_l   \____/_____/     "
)

# ========================
# Spinner
# ========================
spinner=("в Џ" "в ›" "в №" "в ј" "в ґ" "в ¦" "в §" "в ‡")
spinner_index=0

# ========================
# FunГ§ГЈo barra scanner 3 blocos
# ========================
draw_bar() {
    percent=$1
    completed=$2
    timer=$3
    scanner_pos=$4
    filled=$(( BAR_SIZE * percent / 100 ))
    scanner_width=3

    bar="${WHITE}["

    for ((i=0;i<BAR_SIZE;i++)); do
        if [ $i -lt $filled ]; then
            bar+="${LIGHT_CYAN}в–€${NC}${WHITE}"
        else
            rel=$(( (i - scanner_pos + BAR_SIZE) % BAR_SIZE ))
            if [ $rel -lt $scanner_width ]; then
                if [ $rel -eq 0 -o $rel -eq 2 ]; then
                    bar+="${LIGHT_GREEN}в–€${NC}${WHITE}"
                elif [ $rel -eq 1 ]; then
                    bar+="${LIGHT_ORANGE}в–€${NC}${WHITE}"
                fi
            else
                bar+="${GRAY}в–‘${NC}${WHITE}"
            fi
        fi
    done

    bar+="]${NC}"
    echo -ne "$bar $percent% $timer $completed/$TOTAL_ITEMS"
}

# ========================
# Loop principal
# ========================
start_time=$(date +%s)
highlight_index=0
scanner_pos=0

for ((step=0; step<TOTAL_ITEMS; step++)); do
    # Atualiza status
    for ((i=0;i<TOTAL_ITEMS;i++)); do
        if [ $i -lt $step ]; then
            status[$i]="done"
        elif [ $i -eq $step ]; then
            status[$i]="current"
        else
            status[$i]="future"
        fi
    done

    elapsed_item=0
    while [ $elapsed_item -lt ${times[$step]} ]; do
        current_time=$(date +%s)
        elapsed=$(( current_time - start_time ))
        minutes=$(( elapsed / 60 ))
        seconds=$(( elapsed % 60 ))
        timer=$(printf "%02d:%02d" $minutes $seconds)

        tput cup 0 0
        

        # CabeГ§alho fixo
        echo ""
        echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${BOX_CYAN}Fucking Cheaters${NC}"
        echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"
        echo ""

        # ASCII animado
        for ((i=0;i<${#ascii_lines[@]};i++)); do
            if [ $i -eq $highlight_index ]; then
                echo -e "${WHITE}${ascii_lines[$i]}${NC}"
            else
                echo -e "${CYAN}${ascii_lines[$i]}${NC}"
            fi
        done
        highlight_index=$(( (highlight_index + 1) % ${#ascii_lines[@]} ))

        # "Coded By" abaixo do ASCII
        echo ""
        echo -e "${CYAN}  Coded By: KellerSS${NC}"
        echo ""

        # Barra com spinner Г  esquerda
        echo -ne "${LIGHT_CYAN}${spinner[$spinner_index]}${NC} "
        draw_bar $((step*100/TOTAL_ITEMS)) $step $timer $scanner_pos
        spinner_index=$(( (spinner_index + 1) % ${#spinner[@]} ))
        echo -e "\n"

        # Lista dinГўmica com 2 espaГ§os e nova setinha
        for ((i=0;i<TOTAL_ITEMS;i++)); do
            case ${status[$i]} in
                done) echo -e "  ${GREEN}вњ”${NC} ${items[$i]}" ;;
                current) echo -e "  ${LIGHT_CYAN}вћ¤${WHITE} ${items[$i]}" ;; # nova setinha
                future) echo -e "  ${GRAY}вЂў${NC} ${items[$i]}" ;;
            esac
        done

        # Atualiza scanner
        scanner_pos=$(( (scanner_pos + 1) % BAR_SIZE ))
        sleep 0.05
        ((elapsed_item++))
    done
done

# ========================
# Barra final e scan completo
# ========================
clear
end_time=$(date +%s)
elapsed=$(( end_time - start_time ))
minutes=$(( elapsed / 60 ))
seconds=$(( elapsed % 60 ))
timer=$(printf "%02d:%02d" $minutes $seconds)

# CabeГ§alho final
echo ""
echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${AZUL_PERSONAL}Fucking Cheaters${NC}"
echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"
echo ""

# ASCII final
for line in "${ascii_lines[@]}"; do
    echo -e "${CYAN}${line}${NC}"
done
echo -e "${CYAN}  Coded By: KellerSS${NC}"
echo ""

# Barra final 100%
echo -ne "${LIGHT_CYAN}${spinner[$spinner_index]}${NC} "
draw_bar 100 $TOTAL_ITEMS $timer $((BAR_SIZE-1))
echo -e "\n"

# Lista final com 2 espaГ§os e nova setinha
for ((i=0;i<TOTAL_ITEMS;i++)); do
    echo -e "  ${GREEN}вњ”${NC} ${items[$i]}"
done

echo -e "\n${GREEN}вњ… ConcluГ­do!${NC}"
read -p "Pressione ENTER para sair..."