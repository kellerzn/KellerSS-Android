#!/data/data/com.termux/files/usr/bin/bash

clear

# ========================
# Cores ANSI
# ========================

CYAN="\033[0;36m"
BOX_CYAN="\033[38;2;0;200;220m"
BRIGHT_CYAN="\033[1;36m"
ORANGE="\033[38;2;255;140;26m"
WHITE="\033[1;37m"
GREEN="\033[38;2;0;255;85m"
YELLOW="\033[38;2;255;255;85m"
LIGHT_BLUE="\033[1;34m"
RED="\033[0;31m"
NC="\033[0m"

# ========================
# Banner
# ========================

echo ""
echo -e "  ${BRIGHT_CYAN}KellerSS Android${NC} ${BOX_CYAN}Fucking Cheaters${NC}"
echo -e "  ${WHITE}discord.gg/allianceoficial${NC}"

echo ""

echo -e "${BRIGHT_CYAN}"
echo "  _  __      _ _           _____ ______     "
echo " l l/ /___ _l l l ___ _ _l  ___/  ___l     "
echo " l   </ _ ' l l l/ _ \ '__l l__ \___ \\   "
echo " l_l\_\___,_l_l_l\___/_l   \____/_____/     "
echo -e "${NC}"

echo -e "  ${CYAN}Coded By: KellerSS${NC}"

echo ""
echo -e "  ${ORANGE}⚠ Nenhum dispositivo conectado — prosseguindo para reconexão manual.${NC}"

echo -e "  ${BRIGHT_CYAN}┌─RECONEXÃO${NC}"
echo -e "   ${YELLOW}Abra: Configurações → Opções do Desenvolvedor → Depuração sem fio${NC}"
echo -e "   ${YELLOW}Toque em \"Parear com código de pareamento\" e anote a PORTA e o CÓDIGO.${NC}"

echo ""

# ========================
# PAREAMENTO (REAL ADB)
# ========================

echo -ne "  ${BRIGHT_CYAN}▸ Porta de pareamento (ex: 37241):${NC}${GREEN} "
read porta

echo -ne "  ${BRIGHT_CYAN}▸ Código de pareamento (6 dígitos):${NC}${GREEN} "
read codigo

echo ""
echo -e "  ${LIGHT_BLUE}→ Pareando...${NC}"

pair_result=$(adb pair 127.0.0.1:$porta $codigo 2>&1)

if echo "$pair_result" | grep -qi "successfully"; then
    echo -e "  ${GREEN}✔ Pareado com sucesso!${NC}"
else
    echo -e "  ${RED}✖ Falha no pareamento${NC}"
    echo "$pair_result"
fi

echo ""
echo -e "  ${YELLOW}Volte à tela principal de \"Depuração sem fio\".${NC}"
echo -e "  ${YELLOW}Anote a PORTA mostrada ao lado do endereço IP.${NC}"

echo ""

# ========================
# CONEXÃO (REAL ADB)
# ========================

echo -ne "  ${BRIGHT_CYAN}▸ Porta de conexão (ex: 43210):${NC}${GREEN} "
read porta_conexao

echo ""
echo -e "  ${LIGHT_BLUE}→ Conectando...${NC}"

connect_result=$(adb connect localhost:$porta_conexao 2>&1)

# mostra exatamente a linha do adb
echo "  $connect_result"

# mensagem bonita por cima
if echo "$connect_result" | grep -qi "connected"; then
    echo -e "  ${GREEN}✔ Dispositivo conectado!${NC}"
else
    echo -e "  ${RED}✖ Falha na conexão${NC}"
fi

echo ""

echo -ne " ${WHITE}Pressione Enter para voltar ao menu...${NC}"
read