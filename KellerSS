#!/data/data/com.termux/files/usr/bin/bash
clear

# Cores ANSI
CYAN="\033[0;36m"
BRIGHT_CYAN="\033[1;36m"
BLUE="\033[0;34m"
WHITE="\033[1;37m"
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
NC="\033[0m"

# Função para centralizar texto
center() {
    cols=$(tput cols)
    printf "%*s\n" $(( (${#1} + cols) / 2 )) "$1"
}

# Título e Discord
center "${BRIGHT_CYAN}KellerSS Android${NC} ${BLUE}Fucking Cheaters${NC}"
center "${WHITE}discord.gg/allianceoficial${NC}"

echo ""

# ASCII Art (cada linha centralizada)
center "${CYAN} _  __       _ _            ______ ______${NC}"
center "${CYAN}| |/ / ___ _| | | ___ _._|   ____/ ____|${NC}"
center "${CYAN}|   < / _ \ | |/ _ \   __| |__ \\\___  \\${NC}"
center "${CYAN}|_|\\_ \\___,_|_|_|\\___/_ |   \\____/_____/${NC}"

# Coded By
center "${BRIGHT_CYAN}Coded By: KellerSS${NC}"

echo ""

# Menu Principal
center "${BLUE}╔══════════════════════════╗${NC}"
center "${BLUE}║      MENU PRINCIPAL      ║${NC}"
center "${BLUE}╚══════════════════════════╝${NC}"

echo ""

# Status ADB
center "ADB: ${GREEN}● Dispositivo conectado${NC}"

echo ""

# Opções
center "[0] Parear Dispositivo"
center "[1] Escanear FreeFire Normal"
center "[2] Escanear FreeFire Max"
center "[3] Salvar Dump"
center "[S] Sair"

echo ""

# Prompt de escolha
center "${BRIGHT_CYAN}▸ Escolha uma das opções acima:${NC}"
read escolha

case $escolha in
    0)
        center "${GREEN}Você escolheu: Parear Dispositivo${NC}"
        ;;
    1)
        center "${GREEN}Você escolheu: Escanear FreeFire Normal${NC}"
        ;;
    2)
        center "${GREEN}Você escolheu: Escanear FreeFire Max${NC}"
        ;;
    3)
        center "${GREEN}Você escolheu: Salvar Dump${NC}"
        ;;
    [Ss])
        center "${RED}Saindo...${NC}"
        exit 0
        ;;
    *)
        center "${RED}Opção inválida!${NC}"
        ;;
esac